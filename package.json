{
  "name": "nunjucks",
  "description": "A powerful templating engine with inheritance, asynchronous control, and more (jinja2 inspired)",
  "version": "3.2.4",
  "author": "James Long <longster@gmail.com>",
  "type": "module",
  "dependencies": {
    "express": "5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0"
  },
  "scripts": {
    "build": "bun run scripts/bundle.js",
    "lint": "eslint nunjucks",
    "prepare": "bun run build",
    "test": "bun run lint && bun test ./tests/api.js ./tests/compiler.js ./tests/filters.js ./tests/lexer.js ./tests/express.js ./tests/core.js ./tests/precompile.js ./tests/loader.js ./tests/runtime.js ./tests/globals.js ./tests/tests.js ./tests/jinja-compat.js"
  },
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "browser/**",
    "src/**"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mozilla/nunjucks.git"
  },
  "keywords": [
    "template",
    "templating"
  ],
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/mozilla/nunjucks/issues"
  }
}
