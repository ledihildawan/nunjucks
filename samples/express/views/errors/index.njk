<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Nunjucks template error routes - interactive preview of all error types with syntax highlighting and suggested fixes">
  <meta name="robots" content="noindex, nofollow">
  <meta name="author" content="Nunjucks">

  <title>Nunjucks Error Routes ({{ total }} errors) - Interactive Preview</title>

  <meta property="og:title" content="Nunjucks Error Routes - Interactive Preview">
  <meta property="og:description" content="Browse and preview all Nunjucks template error types with syntax highlighting, possible causes, and suggested fixes.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="/errors">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Nunjucks Error Routes">
  <meta name="twitter:description" content="Interactive preview of all Nunjucks template error types">

  <link rel="canonical" href="/errors">

  <style>
    :root {
      color-scheme: light dark;
      interpolate-size: allow-keywords;

      --color-bg-page: light-dark(oklch(97% 0.01 285), oklch(12% 0.01 285));
      --color-bg-panel: light-dark(oklch(100% 0 0), oklch(18% 0.01 285));
      --color-bg-alt: light-dark(oklch(96% 0.01 285), oklch(22% 0.01 285));
      --color-border: light-dark(oklch(90% 0.01 285), oklch(28% 0.02 285));

      --color-text-primary: light-dark(oklch(20% 0.02 285), oklch(95% 0.01 285));
      --color-text-secondary: light-dark(oklch(45% 0.02 285), oklch(75% 0.01 285));

      --color-error-text: light-dark(oklch(45% 0.2 25), oklch(70% 0.18 25));
      --color-error-hover: light-dark(oklch(35% 0.2 25), oklch(55% 0.18 25));

      --color-btn-bg: light-dark(oklch(20% 0.02 285), oklch(90% 0.01 285));
      --color-btn-text: light-dark(oklch(98% 0.01 285), oklch(15% 0.01 285));
      --color-btn-hover: light-dark(oklch(35% 0.02 285), oklch(100% 0 0));

      --color-scrollbar-thumb: light-dark(oklch(65% 0.01 285), oklch(45% 0.02 285));
      --color-scrollbar-track: light-dark(oklch(92% 0.01 285), oklch(20% 0.01 285));

      --scrollbar-width: 8px;

      --sidebar-width: 400px;
      --header-height: 50px;
    }

    *, *::before, *::after { box-sizing: border-box; }
    ::selection { background: oklch(0.55 0.15 285 / 0.3); color: inherit; }
    :root { scrollbar-width: thin; scrollbar-color: var(--color-scrollbar-thumb) var(--color-scrollbar-track); }
    * { scrollbar-width: inherit; scrollbar-color: inherit; }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      margin: 0;
      height: 100vh; display: flex; flex-direction: column;
      background: var(--color-bg-page);
      color: var(--color-text-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .header {
      height: var(--header-height); padding: 0 20px;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-bg-panel);
      display: flex; align-items: center; gap: 20px;
      flex-shrink: 0;
    }
    h1 { font-size: 16px; margin: 0; color: var(--color-text-primary); font-weight: 600; }
    .header-hint { color: var(--color-text-secondary); font-size: 12px; }

    code {
      font-family: ui-monospace, 'SFMono-Regular', Consolas, monospace;
      font-size: 0.85em;
    }

    .item-desc {
      display: block;
      color: var(--color-text-secondary);
      font-size: 12px;
      margin-top: 2px;
    }

    li {
      margin: 8px 0;
      line-height: 1.4;
      list-style: none;
    }

    li.hidden { display: none; }

    .error-card {
      display: block;
      width: 100%;
      text-decoration: none;
      color: var(--color-error-text);
      padding: 2px 4px;
      margin: -2px -4px;
      border-radius: 0.375rem;
      transition: background-color 0.2s ease-out, outline 0.2s ease-out;
      scroll-margin-top: 60px;
    }

    .error-card:hover {
      background: var(--color-bg-alt);
    }

    .error-card.active {
      background: var(--color-error-bg);
      outline: 2px solid var(--color-error-text);
      outline-offset: -2px;
    }

    .search-wrapper {
      position: relative;
    }

    #search-input {
      width: 100%;
      padding: 8px 12px;
      font-size: 13px;
      font-family: inherit;
      background: var(--color-bg-alt);
      border: 1px solid var(--color-border);
      border-radius: 0.375rem;
      color: var(--color-text-primary);
      outline: none;
      transition: border-color 0.2s ease-out, box-shadow 0.2s ease-out;
    }

    #search-input::placeholder { color: var(--color-text-secondary); }

    #search-input:focus {
      border-color: var(--color-error-border);
      box-shadow: 0 0 0 3px oklch(0.55 0.2 25 / 0.15);
    }

    .group.hidden { display: none; }

    .container {
      display: flex; flex: 1; overflow: hidden;
    }

    @property --scroll-mask-t-from {
      syntax: "<length-percentage>";
      inherits: false;
      initial-value: 100%;
    }

    @property --scroll-mask-b-from {
      syntax: "<length-percentage>";
      inherits: false;
      initial-value: 90%;
    }

    @keyframes scroll-mask-y {
      0% {
        --scroll-mask-t-from: 100%;
      }
      10%, 100% {
        --scroll-mask-t-from: var(--scroll-mask-fade-from-t, 92%);
      }
      0%, 90% {
        --scroll-mask-b-from: var(--scroll-mask-fade-from-b, 92%);
      }
      100% {
        --scroll-mask-b-from: 100%;
      }
    }

    .sidebar {
      width: var(--sidebar-width);
      max-width: min(600px, calc(100% - 400px));
      border-right: 1px solid var(--color-border);
      flex-shrink: 0;
      background: var(--color-bg-panel);
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .sidebar-header {
      padding: 15px;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-bg-panel);
      position: sticky;
      top: 0;
    }

    .resize-handle {
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 8px;
      cursor: col-resize;
      background: transparent;
      transition: background-color 0.2s;
    }

    .resize-handle:hover,
    .resize-handle.dragging {
      background: var(--color-error-text);
    }

    .sidebar-content {
      flex: 1;
      overflow-y: auto;
      padding: 15px;
      scrollbar-gutter: stable;

      --scroll-mask-fade-from-t: 92%;
      --scroll-mask-fade-from-b: 92%;

      mask-image:
        linear-gradient(to top, var(--color-bg-panel), var(--color-bg-panel) var(--scroll-mask-t-from), transparent),
        linear-gradient(to bottom, var(--color-bg-panel), var(--color-bg-panel) var(--scroll-mask-b-from), transparent);
      mask-composite: intersect;
      animation: scroll-mask-y linear;
      animation-timeline: scroll(self block);

      scrollbar-width: thin;
      scrollbar-color: var(--color-scrollbar-thumb) var(--color-scrollbar-track);
    }

    .sidebar-content::-webkit-scrollbar { width: var(--scrollbar-width); }
    .sidebar-content::-webkit-scrollbar-track { background: transparent; }
    .sidebar-content::-webkit-scrollbar-thumb {
      background-color: var(--color-scrollbar-thumb);
      border-radius: 9999px;
    }

    .preview {
      flex: 1; display: none; overflow: auto;
      background: var(--color-bg-page);
      scrollbar-gutter: stable;
      scrollbar-width: thin;
      scrollbar-color: var(--color-scrollbar-thumb) var(--color-scrollbar-track);
    }
    .preview.active { display: flex; flex-direction: column; }

    .preview::-webkit-scrollbar { width: var(--scrollbar-width); }
    .preview::-webkit-scrollbar-track { background: transparent; }
    .preview::-webkit-scrollbar-thumb {
      background-color: var(--color-scrollbar-thumb);
      border-radius: 9999px;
    }
    .preview-header {
      padding: 8px 12px; background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border);
      font-size: 13px; display: flex; align-items: center; gap: 10px;
      flex-shrink: 0;
    }
    .preview-header .url { color: var(--color-text-secondary); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .active-dot { color: var(--color-error-text); font-size: 10px; margin-right: 4px; }
    .preview-header .btn {
      background: var(--color-btn-bg); color: var(--color-btn-text); border: none; padding: 4px 10px;
      font-size: 12px; cursor: pointer; font-family: inherit; border-radius: 0.25rem;
      transition: background-color 0.2s ease-out;
    }
    .preview-header .btn:hover { background: var(--color-btn-hover); }
    iframe { flex: 1; border: none; width: 100%; }

    .group { margin-bottom: 10px; container-type: inline-size; }
    .group-header {
      font-size: 14px; color: var(--color-text-secondary); margin: 15px 0 10px;
      border-bottom: 1px solid var(--color-border); padding-bottom: 5px;
      cursor: pointer; user-select: none;
      display: flex; align-items: center; gap: 8px;
      transition: color 0.2s ease-out;
    }
    .group-header:hover { color: var(--color-text-primary); }
    .group-header::before { content: '▶'; font-size: 10px; transition: transform 0.2s; flex-shrink: 0; }
    .group-header.open::before { transform: rotate(90deg); }
    .group-title { text-wrap: balance; word-break: break-word; }
    .group-header .count { color: var(--color-text-secondary); font-weight: normal; flex-shrink: 0; }
    ul { list-style: none; padding: 0; margin: 0; display: none; }
    ul.open { display: block; }

    @container (max-width: 180px) {
      .group-header { flex-wrap: wrap; gap: 4px; }
    }

    @media (max-width: 900px) {
      :root { --sidebar-width: 100%; }
      .container { flex-direction: column; }
      .sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--color-border); }
      .preview { display: none !important; }
      .resize-handle { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }
  </style>
</head>
<body>
  <header class="header" role="banner">
    <h1>Error Routes</h1>
    <span class="header-hint">Browse {{ total }} error types</span>
  </header>

  <div class="container" role="main">
    <aside class="sidebar" aria-label="Error routes list">
      <div class="sidebar-header">
        <div class="search-wrapper">
          <input
            type="search"
            id="search-input"
            placeholder="Search error routes..."
            aria-label="Search error routes"
            autocomplete="off"
            spellcheck="false"
          >
        </div>
      </div>
      <div class="sidebar-content">
        {% for group in groups %}
        <section class="group" aria-labelledby="group-heading-{{ loop.index }}">
          <h2 class="group-header open" id="group-heading-{{ loop.index }}" data-group="{{ loop.index }}" data-original-count="{{ group.items.length }}" role="heading" aria-level="2">
            <span class="group-title">{{ group.name }}</span>
            <span class="count">({{ group.items.length }})</span>
          </h2>
          <ul class="open" id="group-{{ loop.index }}" role="list">
            {% for item in group.items %}
            <li role="listitem">
              <a href="/errors/{{ item.path }}" class="error-card" data-path="{{ item.path }}" data-desc="{{ item.desc }}">
                <code>{{ item.path }}</code>
                <span class="item-desc">{{ item.desc }}</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </section>
        {% endfor %}
      </div>
      <div class="resize-handle" id="resize-handle" role="separator" aria-orientation="vertical" aria-label="Resize sidebar" tabindex="0"></div>
    </aside>

    <div class="preview" id="preview" role="region" aria-label="Error preview" aria-live="polite">
      <div class="preview-header">
        <span class="preview-label">Preview:</span>
        <span class="url" id="preview-url" aria-live="off"></span>
        <span class="active-dot" id="active-dot" hidden>●</span>
        <button class="btn" type="button" onclick="openInNewTab()">Open</button>
      </div>
      <iframe id="preview-frame" src="about:blank" title="Error preview" aria-label="Error preview frame"></iframe>
    </div>
  </div>

  <script>
    const preview = document.getElementById('preview');
    const previewFrame = document.getElementById('preview-frame');
    const previewUrl = document.getElementById('preview-url');
    const activeDot = document.getElementById('active-dot');
    const searchInput = document.getElementById('search-input');
    const resizeHandle = document.getElementById('resize-handle');
    const sidebar = document.querySelector('.sidebar');
    let currentUrl = '';
    let activeLink = null;

    let isResizing = false;
    let startX = 0;
    let startWidth = 0;
    let rafId = null;

    resizeHandle.addEventListener('mousedown', (e) => {
      e.preventDefault();
      isResizing = true;
      startX = e.clientX;
      startWidth = sidebar.offsetWidth;
      resizeHandle.classList.add('dragging');
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
      previewFrame.style.pointerEvents = 'none';
    });

    function onMouseMove(e) {
      if (!isResizing) return;
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = null;
        if (!isResizing) return;
        const diff = e.clientX - startX;
        const containerWidth = document.querySelector('.container').offsetWidth;
        const maxW = Math.min(600, containerWidth - 400);
        const newWidth = Math.min(maxW, Math.max(200, startWidth + diff));
        sidebar.style.width = newWidth + 'px';
      });
    }

    function onMouseUp() {
      if (!isResizing) return;
      isResizing = false;
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
      resizeHandle.classList.remove('dragging');
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
      previewFrame.style.pointerEvents = '';
    }

    document.addEventListener('mousemove', onMouseMove);
    document.addEventListener('mouseup', onMouseUp);

    document.querySelectorAll('.group-header').forEach(header => {
      header.addEventListener('click', () => {
        const index = header.dataset.group;
        const list = document.getElementById('group-' + index);
        header.classList.toggle('open');
        list.classList.toggle('open');
      });
    });

    document.querySelectorAll('.error-card').forEach(card => {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        if (activeLink) activeLink.classList.remove('active');
        activeLink = card;
        activeLink.classList.add('active');
        const path = card.dataset.path;
        currentUrl = '/errors/' + path;
        preview.classList.add('active');
        previewUrl.textContent = currentUrl;
        activeDot.hidden = false;
        previewFrame.src = currentUrl;
        location.hash = 'preview=' + currentUrl;
      });
    });

    function openInNewTab() {
      if (currentUrl) window.open(currentUrl, '_blank');
    }

    if (location.hash.startsWith('#preview=')) {
      const url = location.hash.slice('#preview='.length);
      const path = url.replace('/errors/', '');
      const card = document.querySelector('a[data-path="' + path + '"]');
      if (card) {
        if (activeLink) activeLink.classList.remove('active');
        activeLink = card;
        activeLink.classList.add('active');
        currentUrl = '/errors/' + path;
        preview.classList.add('active');
        previewUrl.textContent = currentUrl;
        activeDot.hidden = false;
        previewFrame.src = currentUrl;
        card.scrollIntoView();
      }
    }

    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      const groups = document.querySelectorAll('.group');
      const allItems = document.querySelectorAll('a[data-path]');

      if (query === '') {
        groups.forEach(g => g.classList.remove('hidden'));
        allItems.forEach(item => item.classList.remove('hidden'));
        groups.forEach(group => {
          const header = group.querySelector('.group-header');
          const originalCount = header.dataset.originalCount;
          const countSpan = header.querySelector('.count');
          countSpan.textContent = `(${originalCount})`;
        });
        return;
      }

      allItems.forEach(item => {
        const path = item.dataset.path.toLowerCase();
        const desc = item.dataset.desc.toLowerCase();
        const matches = path.includes(query) || desc.includes(query);
        item.classList.toggle('hidden', !matches);
      });

      groups.forEach(group => {
        const visibleItems = group.querySelectorAll('a:not(.hidden)');
        group.classList.toggle('hidden', visibleItems.length === 0);
        const header = group.querySelector('.group-header');
        const countSpan = header.querySelector('.count');
        countSpan.textContent = `(${visibleItems.length})`;
      });

    });
  </script>
</body>
</html>
