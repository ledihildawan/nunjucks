<!DOCTYPE html>
<html>
<head>
  <title>Error Routes</title>
  <style>
    :root {
      --sidebar-width: 400px;
      --header-height: 50px;
    }
    * { box-sizing: border-box; }
    body {
      font-family: monospace; margin: 0;
      height: 100vh; display: flex; flex-direction: column;
    }
    .header {
      height: var(--header-height); padding: 0 20px;
      border-bottom: 1px solid #ccc;
      display: flex; align-items: center; gap: 20px;
      flex-shrink: 0;
    }
    h1 { font-size: 16px; margin: 0; }
    .container {
      display: flex; flex: 1; overflow: hidden;
    }
    .sidebar {
      width: var(--sidebar-width); border-right: 1px solid #ccc;
      overflow-y: auto; padding: 15px;
      flex-shrink: 0;
    }
    .preview {
      flex: 1; display: none; overflow: hidden;
    }
    .preview.active { display: flex; flex-direction: column; }
    .preview-header {
      padding: 8px 12px; background: #f5f5f5; border-bottom: 1px solid #ccc;
      font-size: 13px; display: flex; align-items: center; gap: 10px;
      flex-shrink: 0;
    }
    .preview-header .url { color: #666; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .preview-header .btn {
      background: #c00; color: #fff; border: none; padding: 4px 10px;
      font-size: 12px; cursor: pointer; font-family: monospace;
    }
    .preview-header .btn:hover { background: #a00; }
    iframe { flex: 1; border: none; width: 100%; }

    .group { margin-bottom: 10px; }
    .group-header {
      font-size: 14px; color: #666; margin: 15px 0 10px;
      border-bottom: 1px solid #ccc; padding-bottom: 5px;
      cursor: pointer; user-select: none;
      display: flex; align-items: center; gap: 8px;
    }
    .group-header:hover { color: #333; }
    .group-header::before { content: '▶'; font-size: 10px; transition: transform 0.2s; }
    .group-header.open::before { transform: rotate(90deg); }
    .group-header .count { color: #999; font-weight: normal; }
    ul { list-style: none; padding: 0; margin: 0; display: none; }
    ul.open { display: block; }
    li { margin: 4px 0; }
    a { color: #c00; text-decoration: none; padding: 2px 4px; margin: -2px -4px; border-radius: 3px; }
    a:hover { text-decoration: underline; }
    a.active { background: #c00; color: #fff; outline: 2px solid #c00; outline-offset: 1px; }

    @media (max-width: 900px) {
      :root { --sidebar-width: 100%; }
      .container { flex-direction: column; }
      .sidebar { width: 100%; border-right: none; border-bottom: 1px solid #ccc; }
      .preview { display: none !important; }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Error Routes ({{ total }})</h1>
    <span style="color:#999;font-size:12px">Click to preview • Wide screen: side-by-side view</span>
  </div>

  <div class="container">
    <div class="sidebar">
      {% for group in groups %}
      <div class="group">
        <h2 class="group-header open" data-group="{{ loop.index }}">
          {{ group.name }} <span class="count">({{ group.items.length }})</span>
        </h2>
        <ul class="open" id="group-{{ loop.index }}">
          {% for item in group.items %}
          <li><a href="/errors/{{ item.path }}" data-url="/errors/{{ item.path }}">{{ item.path }}</a> - {{ item.desc }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>

    <div class="preview" id="preview">
      <div class="preview-header">
        <span>Preview:</span>
        <span class="url" id="preview-url"></span>
        <button class="btn" onclick="openInNewTab()">Open</button>
      </div>
      <iframe id="preview-frame" src="about:blank"></iframe>
    </div>
  </div>

  <script>
    const preview = document.getElementById('preview');
    const previewFrame = document.getElementById('preview-frame');
    const previewUrl = document.getElementById('preview-url');
    let currentUrl = '';
    let activeLink = null;

    if (location.pathname.startsWith('/errors/') && location.pathname !== '/errors/') {
      location.replace('/errors');
    }

    document.querySelectorAll('.group-header').forEach(header => {
      header.addEventListener('click', () => {
        const index = header.dataset.group;
        const list = document.getElementById('group-' + index);
        header.classList.toggle('open');
        list.classList.toggle('open');
      });
    });

    document.querySelectorAll('a[data-url]').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        if (activeLink) activeLink.classList.remove('active');
        activeLink = link;
        activeLink.classList.add('active');
        currentUrl = link.dataset.url;
        preview.classList.add('active');
        previewUrl.textContent = currentUrl;
        previewFrame.src = currentUrl;
        history.pushState({}, '', currentUrl);
      });
    });

    function openInNewTab() {
      if (currentUrl) window.open(currentUrl, '_blank');
    }

    window.addEventListener('popstate', () => {
      if (location.pathname.startsWith('/errors/')) {
        const url = location.pathname;
        currentUrl = url;
        preview.classList.add('active');
        previewUrl.textContent = url;
        previewFrame.src = url;
        if (activeLink) activeLink.classList.remove('active');
        activeLink = null;
      }
    });
  </script>
</body>
</html>
