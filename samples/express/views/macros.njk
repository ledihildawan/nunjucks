{% macro user_card(name, status) %}
<div class="user-card" style="border: 1px solid #ccc; padding: 10px; margin: 5px;">
  <strong>{{ name }}</strong>
  <span class="status">Status: {{ status }}</span>
</div>
{% endmacro %}

{% macro simple_list(items) %}
<ul>
  {% for item in items %}
  <li>{{ item }}</li>
  {% endfor %}
</ul>
{% endmacro %}
